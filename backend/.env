# ─────────────────────────────────────────────────────
# OpenAI API Key
# Get yours at: https://platform.openai.com/api-keys
# If left as placeholder, the app uses regex-based fallback
# (works without a key but gives simpler answers)
# ─────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o

# MongoDB (optional — runs in-memory if unavailable)
MONGODB_URI=mongodb://localhost:27017/resume-assistant

# Server
PORT=4000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
